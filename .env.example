# Root BaSyx deployment configuration.
HOST_ADDRESS=192.168.1.100

# Custom UI build-time values. The defaults use HOST_ADDRESS.
VITE_PUBLIC_API_BASE=https://${HOST_ADDRESS}/public
VITE_SECURED_API_BASE=https://${HOST_ADDRESS}
VITE_KEYCLOAK_URL=https://${HOST_ADDRESS}/auth
VITE_KEYCLOAK_REALM=basyx
VITE_KEYCLOAK_CLIENT_ID=basyx-web
VITE_AAS_ID=https://example.org/aas/schunk/pgn-plus-p-64-1
VITE_TIMESERIES_ID=https://example.org/submodels/schunk/pgn-plus-p-64-1/timeseries
VITE_POLL_INTERVAL_MS=2000
VITE_REQUEST_TIMEOUT_MS=60000
